# Tokocrypto API Keys
TOKO_API_KEY=your_api_key_here
TOKO_SECRET_KEY=your_secret_key_here

# Trading Settings
SYMBOL=BTC/BIDR
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# Ukuran Transaksi (Berapa banyak koin yang ditransaksikan sekali sinyal)
# Contoh: Jika SYMBOL=BTC/BIDR, maka TRADE_AMOUNT adalah nominal BTC (misal: 0.0001 BTC)
# ATAU nominal BIDR (tergantung logika order). Kita gunakan jumlah koin dasar (base currency).
TRADE_AMOUNT=0.0001

# Mode Simulasi (Sangat direkomendasikan disetel True saat awal agar tidak menggunakan uang asli)
DRY_RUN=True
